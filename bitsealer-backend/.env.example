# ─────────── PostgreSQL ───────────
POSTGRES_DB=bitsealer
POSTGRES_USER=bitsealer
POSTGRES_PASSWORD=change_me_with_a_strong_random_secret

# ─────────── Backend ───────────
DB_HOST=db
DB_PORT=5432
DB_NAME=bitsealer
DB_USER=bitsealer
DB_PASSWORD=change_me_with_a_strong_random_secret
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JPA_SHOW_SQL=false
FLYWAY_ENABLED=true
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─────────── Stamper ───────────
STAMPER_BASE_URL=http://stamper:8000
STAMPER_CALLBACK_TOKEN=replace_with_a_long_random_callback_token