# URL base del backend (se inyecta en build)
# - Para desarrollo local: http://localhost:8080/api
# - Si levantas backend con Docker Compose en la misma máquina y expones 8080, sigue siendo igual.
# - En despliegue, cambia a la URL de tu API pública.
VITE_API_BASE=http://localhost:8080/api

# Puerto del dev server de Vite (opcional)
VITE_PORT=5173
